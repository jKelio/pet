# Database
DATABASE_URL=postgresql://pet:pet_dev_secret@localhost:5432/pet

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=change_me_to_a_long_random_string

# SMTP — Mailpit runs on localhost:1025 via docker compose up mailpit
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@pet.local

# App
APP_BASE_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# SuperAdmin access (comma-separated emails — only these can manage tenants)
# SUPER_ADMIN_EMAILS=admin@example.com,other@example.com
