{
  "name": "@pet/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/presentation/index.ts",
    "build": "bun build src/presentation/index.ts --outdir=dist --target=bun",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@fastify/cookie": "^11",
    "@fastify/cors": "^10",
    "@fastify/rate-limit": "10.3.0",
    "@pet/shared": "workspace:*",
    "drizzle-orm": "^0.38",
    "fastify": "^5",
    "fastify-plugin": "5.1.0",
    "jose": "^6",
    "postgres": "^3",
    "resend": "^4",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.30",
    "typescript": "^5.7"
  }
}
