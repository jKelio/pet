# Required
JWT_SECRET=change_me_to_a_long_random_string
APP_BASE_URL=http://localhost

# SMTP — for local dev the docker-compose Mailpit defaults work without any changes
# For production set these to your real SMTP provider (e.g. Postmark, SES, Brevo)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@pet.local

# GitHub PAT for App Feedback (create issues in jKelio/pet on behalf of the app)
# Needs: issues:write scope. Optional — feedback form returns 503 without it.
# GITHUB_PAT=github_pat_...

# SuperAdmin access (comma-separated emails — only these can manage tenants)
# SUPER_ADMIN_EMAILS=admin@example.com,other@example.com

# Google Gemini AI (optional — AI recommendations are disabled without this)
# Get a key at https://aistudio.google.com/
# GEMINI_API_KEY=your_api_key_here
# GEMINI_MODEL=gemini-2.5-pro

# Optional (defaults shown)
POSTGRES_PASSWORD=pet_dev_secret
CORS_ORIGIN=http://localhost
NODE_ENV=production
