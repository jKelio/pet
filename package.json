{
  "name": "pet-v2",
  "private": true,
  "license": "AGPL-3.0-only",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "tunnel": "bun run scripts/tunnel.ts",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@pet/server",
    "db:migrate": "turbo run db:migrate --filter=@pet/server",
    "db:seed": "turbo run db:seed --filter=@pet/server",
    "db:truncate": "turbo run db:truncate --filter=@pet/server",
    "db:studio": "turbo run db:studio --filter=@pet/server"
  },
  "devDependencies": {
    "turbo": "^2",
    "eslint": "^9",
    "typescript-eslint": "^8"
  }
}
